{
  "uid": "golden-signals",
  "title": "Golden Signals — Command Center",
  "description": "The four Golden Signals: Latency, Traffic, Errors, Saturation",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, app_instance)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, http_route)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🔴 At a Glance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate",
      "description": "Requests per second across all instances",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app_instance=~\"$instance\"}[5m]))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "description": "Percentage of requests returning 4xx/5xx",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_errors_total{app_instance=~\"$instance\"}[5m])) / sum(rate(http_requests_total{app_instance=~\"$instance\"}[5m])) * 100"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency",
      "description": "95th percentile request duration",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\"}[5m])) by (le))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Usage",
      "description": "Node memory usage percentage",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Firing Alerts",
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Service Health",
      "description": "Blackbox probe success (1 = up, 0 = down)",
      "gridPos": { "x": 6, "y": 5, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "min(probe_success{job=\"blackbox-health\"})",
          "legendFormat": "Service Status"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "In-Flight Requests",
      "gridPos": { "x": 12, "y": 5, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_requests_in_flight{app_instance=~\"$instance\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 18, "y": 5, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "📊 LATENCY",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Request Latency — P50 / P95 / P99",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency by Route (P95)",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\"}[5m])) by (le, http_route))",
          "legendFormat": "{{ http_route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5, "lineWidth": 1 }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latency by Instance (P95)",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (le, app_instance))",
          "legendFormat": "{{ app_instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 12,
      "type": "heatmap",
      "title": "Latency Heatmap",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_request_duration_seconds_bucket{app_instance=~\"$instance\", http_route=~\"$route\"}[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{ le }}"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" }
      }
    },

    {
      "id": 300,
      "type": "row",
      "title": "📈 TRAFFIC",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m]))",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "drawStyle": "line" }
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app_instance=~\"$instance\"}[5m])) by (http_route)",
          "legendFormat": "{{ http_route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Request Rate by Instance",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (app_instance)",
          "legendFormat": "{{ app_instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Request Rate by Method",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (http_method)",
          "legendFormat": "{{ http_method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },

    {
      "id": 400,
      "type": "row",
      "title": "⚠️ ERRORS",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Error Rate (%)",
      "gridPos": { "x": 0, "y": 43, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_errors_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) / sum(rate(http_requests_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Errors by Route",
      "gridPos": { "x": 12, "y": 43, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_errors_total{app_instance=~\"$instance\"}[5m])) by (http_route)",
          "legendFormat": "{{ http_route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Errors by Status Code",
      "gridPos": { "x": 0, "y": 51, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_errors_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (http_status_code)",
          "legendFormat": "{{ http_status_code }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Errors by Instance",
      "gridPos": { "x": 12, "y": 51, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_errors_total{app_instance=~\"$instance\", http_route=~\"$route\"}[5m])) by (app_instance)",
          "legendFormat": "{{ app_instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 500,
      "type": "row",
      "title": "🔥 SATURATION",
      "gridPos": { "x": 0, "y": 59, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "In-Flight Requests",
      "gridPos": { "x": 0, "y": 60, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "http_requests_in_flight{app_instance=~\"$instance\"}",
          "legendFormat": "{{ app_instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Node CPU %",
      "gridPos": { "x": 0, "y": 68, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Node Memory Usage",
      "gridPos": { "x": 12, "y": 68, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },

    {
      "id": 600,
      "type": "row",
      "title": "📋 LOGS",
      "gridPos": { "x": 0, "y": 76, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 25,
      "type": "logs",
      "title": "Recent Error Logs",
      "gridPos": { "x": 0, "y": 77, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"app-.*\"} |= \"ERROR\" or {service=~\"app-.*\"} |= \"status_code\": \"5"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 26,
      "type": "logs",
      "title": "All Application Logs",
      "gridPos": { "x": 0, "y": 85, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"app-.*\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ]
}
